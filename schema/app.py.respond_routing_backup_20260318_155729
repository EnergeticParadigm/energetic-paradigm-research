def load_client_registry() -> dict:
    p = Path("/Users/wesleyshu/ep_system/ep_api_system/client_registry.json")
    try:
        if not p.exists():
            return {"tokens": {}}
        data = json.loads(p.read_text(encoding="utf-8"))
        if isinstance(data, dict):
            data.setdefault("tokens", {})
            return data
        return {"tokens": {}}
    except Exception:
        return {"tokens": {}}

def require_client_auth(authorization: str, scope: str) -> dict:
    if not authorization or not str(authorization).startswith("Bearer "):
        raise HTTPException(status_code=401, detail="Missing bearer token")
    token = str(authorization).split(" ", 1)[1].strip()
    registry = load_client_registry()
    tokens = registry.get("tokens", {}) if isinstance(registry, dict) else {}
    record = tokens.get(token)
    if not isinstance(record, dict) or not record.get("active", False):
        raise HTTPException(status_code=403, detail="Invalid client token")
    scopes = record.get("scopes", [])
    if isinstance(scopes, list) and scopes and scope not in scopes:
        raise HTTPException(status_code=403, detail="Scope not allowed")
    return record


class InputPayload(BaseModel):
    text: str

class RoutingPayload(BaseModel):
    preferred_provider: Optional[str] = "ep_api"
    allowed_providers: Optional[List[str]] = ["ep_api"]
    fallback_provider: Optional[str] = "local"

class OutputPayload(BaseModel):
    include_trace: Optional[bool] = True
    include_provider: Optional[bool] = True
    language: Optional[str] = "en"

class EPPayload(BaseModel):
    mode: Optional[str] = "deep"
    depth: Optional[str] = "long"

class EPUnifiedRequest(BaseModel):
    request_id: Optional[str] = ""
    input: InputPayload
    routing: Optional[RoutingPayload] = RoutingPayload()
    output: Optional[OutputPayload] = OutputPayload()
    ep: Optional[EPPayload] = EPPayload()

def candidate_urls() -> List[str]:
    urls = []
    for u in [EP_REAL_BACKEND_URL, EP_BACKEND_URL, EP_ENGINE_URL, EP_API_CONNECTOR_URL]:
        if not u:
            continue
        if u.endswith("/v1/ep/respond") or u.endswith("/listen"):
            urls.append(u)
        else:
            urls.append(u + "/v1/ep/respond")
    seen = []
    for u in urls:
        if u not in seen:
            seen.append(u)
    return seen

def call_backend(req: EPUnifiedRequest) -> Dict[str, Any]:
    urls = candidate_urls()
    if not urls:
        urls = ["http://127.0.0.1:8001/listen"]
    text = str(req.input.text or "").strip()
    if text and not text.startswith("ep/trigger1"):
        text = "ep/trigger1 " + text
    payload = {
        "text": text
    }

    last_error = None
    for url in urls:
        try:
            request = urllib.request.Request(
                url=url,
                data=json.dumps(payload).encode("utf-8"),
                headers={
                    "Content-Type": "application/json",
                    "x-ep-authenticated": "true",
                    "x-ep-source": "ep_api",
                    "x-ep-session-id": req.request_id or ("ep_api_" + str(int(time.time() * 1000))),
                    "x-ep-client-fp": "local_ep_api_client",
                },
                method="POST",
            )
            with urllib.request.urlopen(request, timeout=60, context=ssl.create_default_context()) as resp:
                body = resp.read().decode("utf-8", errors="ignore")
                obj = json.loads(body)
                if isinstance(obj, dict):
                    return obj
        except Exception as e:
            last_error = str(e)

    raise RuntimeError(last_error or "ep_api backend call failed")

# BEGIN EP 8010 BOUNDARY AUTH
def _ep_boundary_collect_tokens(obj):
    found = set()
    stack = [obj]
    while stack:
        cur = stack.pop()
        if isinstance(cur, dict):
            for k, v in cur.items():
                lk = str(k).lower()
                if isinstance(v, str):
                    s = v.strip()
                    if s and (
                        any(w in lk for w in ["token", "bearer", "secret", "auth", "access", "api_key", "apikey"])
                        or re.fullmatch(r"[A-Za-z0-9._~+/=-]{16,}", s)
                    ):
                        found.add(s)
                stack.append(v)
        elif isinstance(cur, list):
            stack.extend(cur)
        elif isinstance(cur, str):
            s = cur.strip()
            if s and re.fullmatch(r"[A-Za-z0-9._~+/=-]{16,}", s):
                found.add(s)
    return found

def ep_boundary_require_bearer(authorization: str = Header(None)):
    if not authorization or not str(authorization).startswith("Bearer "):
        raise HTTPException(status_code=401, detail="Missing Bearer token")
    token = str(authorization).split(" ", 1)[1].strip()
    if not token:
        raise HTTPException(status_code=401, detail="Empty Bearer token")

    p = Path("/Users/wesleyshu/ep_system/ep_api_system/client_registry.json")
    try:
        registry = json.loads(p.read_text(encoding="utf-8")) if p.exists() else {}
    except Exception:
        registry = {}

    if not isinstance(registry, dict):
        registry = {}

    allowed = set()

    explicit = registry.get("external_boundary_bearer_token")
    if isinstance(explicit, str) and explicit.strip():
        allowed.add(explicit.strip())

    token_map = registry.get("tokens", {})
    if isinstance(token_map, dict):
        for key, meta in token_map.items():
            if isinstance(key, str) and key.strip():
                if not isinstance(meta, dict) or meta.get("active", True):
                    allowed.add(key.strip())

    if "_ep_boundary_collect_tokens" in globals():
        try:
            allowed.update(_ep_boundary_collect_tokens(registry))
        except Exception:
            pass

    if not allowed:
        raise HTTPException(status_code=503, detail="No registered boundary token")
    if token not in allowed:
        raise HTTPException(status_code=403, detail="Invalid Bearer token")
    return True

