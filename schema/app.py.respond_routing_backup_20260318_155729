@app.post("/v1/ep/respond", dependencies=[Depends(ep_boundary_require_bearer)])
def respond(payload: EPUnifiedRequest, authorization: str = Header(default="")) -> Dict[str, Any]:
    require_client_auth(authorization, "respond")
    return call_backend(payload)

@app.post("/v1/ep/analyze", dependencies=[Depends(ep_boundary_require_bearer)])
def analyze(payload: EPUnifiedRequest, authorization: str = Header(default="")) -> Dict[str, Any]:
    require_client_auth(authorization, "analyze")
    return call_backend(payload)


# === EP_TRIGGER1_REAL_COMPAT_SHIM ===
def _ep_trigger1_real_normalize(payload):
    try:
        if payload is None:
            payload = {}
        if not isinstance(payload, dict):
            if hasattr(payload, "model_dump"):
                payload = payload.model_dump()
            elif hasattr(payload, "dict"):
                payload = payload.dict()
            else:
                payload = {"input": {"text": str(payload)}}

        raw_input = payload.get("input")
        if isinstance(raw_input, str):
            raw_input = {"text": raw_input}
        elif raw_input is None:
            raw_input = {}
        elif not isinstance(raw_input, dict):
            raw_input = {"text": str(raw_input)}

        text = payload.get("text")
        if text is None:
            text = raw_input.get("text") or raw_input.get("question") or ""
        text = str(text or "").strip()

        if text.startswith("ep/trigger1"):
            full_text = text
            question = text[len("ep/trigger1"):].strip()
        else:
            question = raw_input.get("question")
            if question is None:
                question = text
            question = str(question or "").strip()
            full_text = ("ep/trigger1 " + question).strip()

        raw_input["text"] = full_text
        raw_input["question"] = question
        raw_input["trigger"] = "ep/trigger1"

        payload["text"] = full_text
        payload["input"] = raw_input

        routing = payload.get("routing")
        if not isinstance(routing, dict):
            routing = {}
        routing.setdefault("preferred_provider", "ep_api")
        routing.setdefault("allowed_providers", ["ep_api"])
        payload["routing"] = routing

        output = payload.get("output")
        if not isinstance(output, dict):
            output = {}
        output.setdefault("include_trace", True)
        output.setdefault("include_provider", True)
        output.setdefault("language", payload.get("language", "en") or "en")
        payload["output"] = output

        ep_block = payload.get("ep")
        if not isinstance(ep_block, dict):
            ep_block = {}
        ep_block.setdefault("mode", "deep")
        ep_block.setdefault("depth", "long")
        ep_block.setdefault("entry_trigger", "ep/trigger1")
        payload["ep"] = ep_block

        payload.setdefault("mode", "respond")
        payload.setdefault("language", "en")
        return payload
    except Exception:
        return payload

