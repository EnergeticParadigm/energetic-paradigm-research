{
  "version": "routing_policy_v1_3",
  "policy_enabled": true,
  "description": "Keep safe OpenAI-first rules. Keep only cost-sensitive internal local-first. Remove raw internal compare local-first as forced local routing.",
  "defaults": {
    "preferred_provider": "openai",
    "allowed_providers": [
      "openai",
      "local"
    ],
    "fallback_provider": "local",
    "allow_fallback": true
  },
  "pre_routing_rules": [
    {
      "id": "executive_format_to_openai",
      "priority": 100,
      "when": {
        "output_format_in": [
          "executive"
        ]
      },
      "select": {
        "preferred_provider": "openai",
        "allowed_providers": [
          "openai"
        ],
        "fallback_provider": "openai",
        "allow_fallback": false
      },
      "reason": "executive_facing_output"
    },
    {
      "id": "public_safe_summary_to_openai",
      "priority": 95,
      "when": {
        "input_contains_any": [
          "public-safe summary",
          "public safe summary",
          "public summary",
          "executive summary",
          "publication-safe",
          "publication safe",
          "external-facing",
          "external facing",
          "press statement",
          "non-public draft"
        ]
      },
      "select": {
        "preferred_provider": "openai",
        "allowed_providers": [
          "openai"
        ],
        "fallback_provider": "openai",
        "allow_fallback": false
      },
      "reason": "public_facing_compression"
    },
    {
      "id": "short_technical_to_openai",
      "priority": 90,
      "when": {
        "all": [
          {
            "ep_depth_in": [
              "short",
              "medium"
            ]
          },
          {
            "input_contains_any": [
              "schema",
              "trace",
              "routing",
              "dispatch",
              "fallback",
              "latency",
              "token accounting",
              "token usage",
              "response fields",
              "provider-independent orchestration",
              "provider independent orchestration"
            ]
          }
        ]
      },
      "select": {
        "preferred_provider": "openai",
        "allowed_providers": [
          "openai"
        ],
        "fallback_provider": "openai",
        "allow_fallback": false
      },
      "reason": "short_precision_explanation"
    },
    {
      "id": "short_standard_to_openai",
      "priority": 80,
      "when": {
        "all": [
          {
            "ep_mode_in": [
              "standard"
            ]
          },
          {
            "ep_depth_in": [
              "short"
            ]
          }
        ]
      },
      "select": {
        "preferred_provider": "openai",
        "allowed_providers": [
          "openai"
        ],
        "fallback_provider": "openai",
        "allow_fallback": false
      },
      "reason": "short_polished_response"
    },
    {
      "id": "cost_sensitive_internal_local_first",
      "priority": 65,
      "when": {
        "all": [
          {
            "any": [
              {
                "ep_mode_in": [
                  "domain",
                  "deep"
                ]
              },
              {
                "ep_depth_in": [
                  "medium",
                  "long"
                ]
              }
            ]
          },
          {
            "input_contains_any": [
              "cost-sensitive",
              "cost sensitive",
              "budget-sensitive",
              "budget sensitive"
            ]
          },
          {
            "input_contains_any": [
              "internal analysis",
              "private note",
              "working draft",
              "internal memo",
              "raw analysis"
            ]
          }
        ]
      },
      "select": {
        "preferred_provider": "local",
        "allowed_providers": [
          "local",
          "openai"
        ],
        "fallback_provider": "openai",
        "allow_fallback": true
      },
      "reason": "cost_sensitive_internal_work"
    }
  ],
  "policy_outputs": {
    "attach_reason": true,
    "attach_matched_rule_id": true
  }
}
